  // ── CSRF token acquisition ────────────────────────────────────────────────────
  let csrfToken_str = '';

  try {
    if (window.parent && typeof window.parent.csrf_token === 'string' && window.parent.csrf_token) {
      csrfToken_str = window.parent.csrf_token;
    }
    if (!csrfToken_str && typeof window.csrf_token === 'string' && window.csrf_token) {
      csrfToken_str = window.csrf_token;
    }
    if (!csrfToken_str && document.cookie) {
      const m_arr = document.cookie.match(/(?:^|;\s*)csrf_token=([^;]+)/);
      if (m_arr && m_arr[1]) csrfToken_str = decodeURIComponent(m_arr[1]);
    }
    if (!csrfToken_str) {
      const meta_el = document.querySelector("meta[name='csrf_token']");
      if (meta_el) csrfToken_str = meta_el.getAttribute('content') || '';
    }
  } catch (e) {
    console.warn('[vm-backup] CSRF token discovery failed:', e);
  }

  if (!csrfToken_str) {
    csrfToken_str = "<?= htmlspecialchars($_GET['csrf_token'] ?? ($_COOKIE['csrf_token'] ?? ''), ENT_QUOTES) ?>";
  }

  if (!csrfToken_str) {
    console.warn('[vm-backup] CSRF token could not be determined — write operations may fail');
  }


