  </div>

</div><!-- /#vmbr-layout -->

<div id="vmbr-schedule-section">
  <div id="vmbr-schedule-list"></div>
</div>

</div><!-- /#vm-backup-and-restore_beta-page -->

<!-- ── Folder picker modal ─────────────────────────────────────────────── -->
<div id="vmbr-folder-picker-modal" class="vmbr-modal">
  <div class="vmbr-modal-content">
    <div class="vmbr-modal-header">
      <span id="vmbr-folder-picker-title">Select Folder</span>
      <button type="button" id="vmbr-folder-close-btn">Close</button>
    </div>
    <div id="vmbr-folder-breadcrumb" class="vmbr-breadcrumb"></div>
    <div id="vmbr-folder-list" class="vmbr-folder-list"></div>
    <div class="vmbr-modal-footer">
      <button type="button" id="vmbr-folder-create-btn">Create Folder</button>
      <span id="vmbr-new-folder-wrap" style="display:none;">
        <input type="text" id="vmbr-new-folder-name" placeholder="Folder name">
        <button type="button" id="vmbr-new-folder-ok-btn">OK</button>
        <button type="button" id="vmbr-new-folder-cancel-btn">Cancel</button>
      </span>
      <button type="button" id="vmbr-folder-confirm-btn">Done</button>
