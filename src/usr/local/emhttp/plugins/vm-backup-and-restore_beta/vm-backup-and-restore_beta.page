  // ── Backup status poller ──────────────────────────────────────────────────
  (function backupStatusPoller() {
    fetch('/plugins/vm-backup-and-restore_beta/helpers/backup_status_check.php', { credentials: 'same-origin' })
      .then(res => res.json())
      .then(data => {
        const el = document.getElementById('status-text');
        if (el) el.textContent = data.status;
        lastStatus = data.status;
      })
      .catch(() => {
        const el = document.getElementById('status-text');
        if (el) el.textContent = 'No Backup Running';
        lastStatus = 'No Backup Running';
      })
      .finally(() => {
        const delay = (lastStatus && lastStatus.includes('Running')) ? 1000 : 4000;
        setTimeout(backupStatusPoller, delay);
