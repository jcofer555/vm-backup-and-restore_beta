<?php
// ── Constants ──────────────────────────────────────────────────────────────
const CFG_PATH         = '/boot/config/plugins/vm-backup-and-restore/settings.cfg';
const CFG_RESTORE_PATH = '/boot/config/plugins/vm-backup-and-restore/settings_restore.cfg';

// ── Backup config defaults ─────────────────────────────────────────────────
$backup_defaults_arr = [
    'VMS_TO_BACKUP'        => '',
    'BACKUP_DESTINATION'   => '',
    'BACKUPS_TO_KEEP'      => '0',
    'BACKUP_OWNER'         => 'nobody',
    'DRY_RUN'              => 'no',
    'NOTIFICATIONS'        => 'no',
    'NOTIFICATION_SERVICE' => '',
    'WEBHOOK_DISCORD'      => '',
    'WEBHOOK_GOTIFY'       => '',
    'WEBHOOK_NTFY'         => '',
    'WEBHOOK_PUSHOVER'     => '',
    'WEBHOOK_SLACK'        => '',
    'PUSHOVER_USER_KEY'    => '',
];

$existing_arr = file_exists(CFG_PATH) ? (parse_ini_file(CFG_PATH) ?: []) : [];
foreach ($backup_defaults_arr as $key_str => $val_str) {
    if (!array_key_exists($key_str, $existing_arr)) {
        $existing_arr[$key_str] = $val_str;
    }
}
$cfg_text_str = '';
foreach ($backup_defaults_arr as $key_str => $default_str) {
    $cfg_text_str .= $key_str . '="' . $existing_arr[$key_str] . '"' . "\n";
}
@file_put_contents(CFG_PATH, $cfg_text_str);
$settings_arr = $existing_arr;

// ── Restore config defaults ────────────────────────────────────────────────
$restore_defaults_arr = [
    'LOCATION_OF_BACKUPS'          => '',
    'VMS_TO_RESTORE'               => '',
    'VERSIONS'                     => '',
    'RESTORE_DESTINATION'          => '/mnt/user/domains',
    'DRY_RUN_RESTORE'              => 'no',
    'NOTIFICATIONS_RESTORE'        => 'no',
    'NOTIFICATION_SERVICE_RESTORE' => '',
    'WEBHOOK_DISCORD_RESTORE'      => '',
    'WEBHOOK_GOTIFY_RESTORE'       => '',
    'WEBHOOK_NTFY_RESTORE'         => '',
    'WEBHOOK_PUSHOVER_RESTORE'     => '',
    'WEBHOOK_SLACK_RESTORE'        => '',
    'PUSHOVER_USER_KEY_RESTORE'    => '',
];

$existing_restore_arr = file_exists(CFG_RESTORE_PATH) ? (parse_ini_file(CFG_RESTORE_PATH) ?: []) : [];
foreach ($restore_defaults_arr as $key_str => $val_str) {
    if (!array_key_exists($key_str, $existing_restore_arr)) {
        $existing_restore_arr[$key_str] = $val_str;
    }
}
$restore_cfg_text_str = '';
foreach ($restore_defaults_arr as $key_str => $default_str) {
    $restore_cfg_text_str .= $key_str . '="' . $existing_restore_arr[$key_str] . '"' . "\n";
}
@file_put_contents(CFG_RESTORE_PATH, $restore_cfg_text_str);
$restore_settings_arr = $existing_restore_arr;

// ── Sibling plugin detection ───────────────────────────────────────────────
$sibling_plugin_checks_arr = [
    'automover' => [
        'plg'   => '/boot/config/plugins/automover.plg',
        'page'  => '/usr/local/emhttp/plugins/automover/automover.page',
        'label' => 'Automover',
        'url'   => '/Settings/automover',
    ],
    'flash-backup' => [
        'plg'   => '/boot/config/plugins/flash-backup.plg',
        'page'  => '/usr/local/emhttp/plugins/flash-backup/flash-backup.page',
        'label' => 'Flash Backup',
        'url'   => '/Settings/flash-backup',
    ],
    'automover_beta' => [
        'plg'   => '/boot/config/plugins/automover_beta.plg',
        'page'  => '/usr/local/emhttp/plugins/automover_beta/automover_beta.page',
        'label' => 'Automover (Beta)',
        'url'   => '/Settings/automover_beta',
    ],
    'flash-backup_beta' => [
        'plg'   => '/boot/config/plugins/flash-backup_beta.plg',
        'page'  => '/usr/local/emhttp/plugins/flash-backup_beta/flash-backup_beta.page',
        'label' => 'Flash Backup (Beta)',
        'url'   => '/Settings/flash-backup_beta',
    ],
      'vm-backup-and-restore' => [
        'plg'   => '/boot/config/plugins/vm-backup-and-restore.plg',
        'page'  => '/usr/local/emhttp/plugins/vm-backup-and-restore/vm-backup-and-restore.page',
        'label' => 'VM Backup & Restore',
        'url'   => '/Settings/vm-backup-and-restore',
    ],
];
$sibling_plugins_arr = [];
$current_plugin_str  = basename(dirname(__FILE__)); // e.g. vm-backup-and-restore
foreach ($sibling_plugin_checks_arr as $key_str => $check_arr) {
    // Skip self
    if ($key_str === $current_plugin_str) continue;
    if (file_exists($check_arr['plg']) && file_exists($check_arr['page'])) {
        $sibling_plugins_arr[$key_str] = $check_arr;
    }
}
$has_siblings_bool = !empty($sibling_plugins_arr);

// Sort siblings alphabetically by label — current plugin is never shown as an option.
$all_plugin_options_arr = $sibling_plugins_arr;
uasort($all_plugin_options_arr, fn($a, $b) => strcmp($a['label'], $b['label']));


$unraid_version_str = '7.1';
if (file_exists('/etc/unraid-version')) {
    $ver_data_arr = parse_ini_file('/etc/unraid-version');
    if (!empty($ver_data_arr['version'])) {
        $unraid_version_str = $ver_data_arr['version'];
    }
}
$isResponsiveWebgui = version_compare($unraid_version_str, '7.2.0-beta', '>=');

// ── Notification service list ──────────────────────────────────────────────
$notif_services_arr            = ['Discord', 'Gotify', 'Ntfy', 'Pushover', 'Slack', 'Unraid'];
$selected_services_arr         = array_filter(explode(',', $settings_arr['NOTIFICATION_SERVICE'] ?? ''));
$selected_services_restore_arr = array_filter(explode(',', $restore_settings_arr['NOTIFICATION_SERVICE_RESTORE'] ?? ''));
?>

<script>
'use strict';
const HELPERS_BASE_STR  = '/plugins/vm-backup-and-restore/helpers';
const POLL_FAST_MS_INT  = 1000;
const POLL_SLOW_MS_INT  = 4000;

let csrfToken_str = "<?= $_GET['csrf_token'] ?? ($_COOKIE['csrf_token'] ?? '') ?>";
if (!csrfToken_str || csrfToken_str === 'undefined') {
  try {
    if (typeof window.csrf_token !== 'undefined' && window.csrf_token) {
      csrfToken_str = window.csrf_token;
    } else if (document.querySelector("meta[name='csrf_token']")) {
      csrfToken_str = document.querySelector("meta[name='csrf_token']").getAttribute('content');
    } else if (document.cookie.includes('csrf_token=')) {
      const m_arr = document.cookie.match(/csrf_token=([^;]+)/);
      if (m_arr) csrfToken_str = decodeURIComponent(m_arr[1]);
    } else if (window.parent && window.parent.csrf_token) {
      csrfToken_str = window.parent.csrf_token;
    }
  } catch (e_err) { console.warn('[vm-backup] CSRF discovery failed:', e_err); }
}
</script>

