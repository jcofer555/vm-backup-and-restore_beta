        <button type="button" id="vmbr-log-copy-btn" title="Copy log to clipboard">Copy Log</button>
        <span id="vmbr-log-toast"></span>
      </div>
      <div class="vmbr-log-scroll-group">
        <span><button type="button" id="vmbr-log-scroll-top-btn" title="Scroll to top">&#8679;</button></span>
        <span><button type="button" id="vmbr-log-autoscroll-btn" title="Scroll to bottom / toggle auto-scroll">&#8681;</button></span>
      </div>
