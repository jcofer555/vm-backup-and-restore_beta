  // ── Malformed backup scanner ──────────────────────────────────────────────
  function formatMissingList(arr) {
    if (arr.length === 1) return arr[0];
    if (arr.length === 2) return arr[0] + ' and ' + arr[1];
    return arr.slice(0, -1).join(', ') + ', and ' + arr[arr.length - 1];
  }

  function scanMalformedBackups() {
    const restorePath = $('#location_of_backups').val();
    if (!restorePath) return;

    $.getJSON(
      '/plugins/vm-backup-and-restore_beta/helpers/scan_malformed_backups.php',
      { restore_path: restorePath },
      function (data) {
        if (!data || data.length === 0) { $('#malformed-warning-container').empty(); return; }

        let message = '';
        if (data.length === 1) {
          const b = data[0];
          message = `⚠ ${b.vm} - Backup with timestamp ${b.backup} is missing ${formatMissingList(b.missing)}<br>This backup will not be included to be restored`;
        } else {
          message = '⚠ Missing files:<br>';
          data.forEach(b => { message += `${b.vm} - ${b.backup} - ${formatMissingList(b.missing)}<br>`; });
          message += 'These backups will not be included to be restored';
        }

        $('#malformed-warning-container').html(`
          <div style="background:#7f1d1d;color:#fff;padding:10px;border-radius:4px;margin-bottom:12px;font-weight:600;max-width:391px;white-space:normal;">
            ${message}
          </div>
        `);
      }
    );
  }

  let malformedPollerRunning = false;

  function startMalformedPolling() {
    if (malformedPollerRunning) return;
    malformedPollerRunning = true;
    malformedLoop();
  }

  function stopMalformedPolling() {
    malformedPollerRunning = false;
  }

  function malformedLoop() {
    if (!malformedPollerRunning) return;
    Promise.resolve()
      .then(() => scanMalformedBackups())
      .finally(() => { if (malformedPollerRunning) setTimeout(malformedLoop, 1000); });
  }

  // ── Version fields ────────────────────────────────────────────────────────
  function scheduleRebuildVersionFields() {
    clearTimeout(rebuildTimer);
    rebuildTimer = setTimeout(_doRebuildVersionFields, 150);
  }

  function _doRebuildVersionFields() {
    if (versionRebuildInProgress) { rebuildTimer = setTimeout(_doRebuildVersionFields, 150); return; }

    const container = $('#version-fields-container');
    const wrapper = $('#version-fields-wrapper');

    container.empty();
    $('#malformed-warning-container').empty();

    const restorePath = $('#location_of_backups').val().trim();
    if (!restorePath) { wrapper.hide(); return; }

    const rawSelected = $('#vm-hidden-restore').val() || '';
    const selectedVMs = rawSelected.split(',').map(s => s.trim()).filter(Boolean);
    if (selectedVMs.length === 0) { wrapper.hide(); return; }

    wrapper.show();
    versionRebuildInProgress = true;

    let pendingRequests = selectedVMs.length;
    const vmVersionData = {};

    selectedVMs.forEach(vm => {
      $.getJSON('/plugins/vm-backup-and-restore_beta/helpers/get_vm_versions.php',
        { vm, restore_path: restorePath },
        function (versions) {
          vmVersionData[vm] = versions;
          pendingRequests--;

          if (pendingRequests === 0) {
            selectedVMs.forEach(vm => {
              const versions = vmVersionData[vm] || [];
              const fieldWrapper = $(`
                <div class="form-pair version-field">
                  <label class="version-label-${vm.replace(/\s+/g, '_')}" style="color:#ad57df !important;font-weight:bold;">
                    Version for ${vm}:
                  </label>
                  <span>
                    <select name="VERSION_${vm}" data-vm="${vm}" class="version-select"></select>
                  </span>
                </div>
              `);

              const select = fieldWrapper.find('select');

              if (!versions || versions.length === 0) {
                select.prop('disabled', true).append('<option selected style="color:#999;">No backups found</option>');
              } else {
                const validVersions = versions.filter(v => !v.malformed);
                if (validVersions.length === 0) {
                  select.prop('disabled', true).append('<option selected style="color:#999;">No backups with all 3 files exist</option>');
                } else {
                  validVersions.forEach((v, idx) => {
                    let label = v.display;
                    if (idx === 0) label += ' (LATEST)';
                    if (validVersions.length > 1 && idx === validVersions.length - 1) label += ' (OLDEST)';
                    select.append(`<option value="${v.raw}">${label}</option>`);
                  });
                  select.val(validVersions[0].raw).prop('disabled', false);
                }
              }

              fieldWrapper.find('label').attr('title', `Select which backup version to restore for ${vm}`);
              container.append(fieldWrapper);
            });

            if (window._fbbProcessLabels) window._fbbProcessLabels(container);
            versionRebuildInProgress = false;
          }
        }
      ).fail(function () {
        pendingRequests--;
        if (pendingRequests === 0) versionRebuildInProgress = false;
      });
    });
  }

  // Refresh versions on focus
  $(document).on('focus', '.version-select', function () {
    const select = $(this);
    const vm = select.data('vm');
    const restorePath = $('#location_of_backups').val().trim();
    if (!vm || !restorePath) return;

    const currentValue = select.val();

    $.getJSON('/plugins/vm-backup-and-restore_beta/helpers/get_vm_versions.php',
      { vm, restore_path: restorePath },
      function (versions) {
        select.empty();
        if (!versions || versions.length === 0) {
          select.prop('disabled', true).append('<option selected style="color:#999;">No backups found</option>');
          return;
        }
        const validVersions = versions.filter(v => !v.malformed);
        if (validVersions.length === 0) {
          select.prop('disabled', true).append('<option selected style="color:#999;">No backups with all 3 files exist</option>');
        } else {
          validVersions.forEach((v, idx) => {
            let label = v.display;
            if (idx === 0) label += ' (LATEST)';
            if (validVersions.length > 1 && idx === validVersions.length - 1) label += ' (OLDEST)';
            select.append(`<option value="${v.raw}">${label}</option>`);
          });
          select.val(validVersions.some(v => v.raw === currentValue) ? currentValue : validVersions[0].raw);
          select.prop('disabled', false);
        }
      }
    );
  });

  // ── Restore VM dropdown + folder loading ──────────────────────────────────
  $(document).ready(function () {
    const dropdown = $('#vm-dropdown-restore');
    const list = dropdown.find('.vm-dropdown-list-restore');
    const label = dropdown.find('.vm-dropdown-label-restore');

    let originalConfigRestoreSelection = ($('#vm-hidden-restore').val() || '')
      .split(',').map(s => s.trim()).filter(Boolean);

    function ensureHiddenFieldRestore(value) {
      let hidden = $('#vm-hidden-restore');
      if (!hidden.length) {
        hidden = $('<input>', { type: 'hidden', id: 'vm-hidden-restore', name: 'VMS_TO_RESTORE' })
          .appendTo(dropdown.parent());
      }
      hidden.val(value);
    }

    function enforceVersionVisibility() {
      const hasPath = $('#location_of_backups').val().trim() !== '';
      const hasSelection = ($('#vm-hidden-restore').val() || '').trim() !== '';
      if (!hasPath || !hasSelection) { $('#version-fields-wrapper').hide(); return false; }
      $('#version-fields-wrapper').show();
      return true;
    }

    function updateRestoreLabel() {
      const checked = list.find('input:checked').map(function () { return $(this).val(); }).get();
      if (checked.length === 0) {
        label.text('Select VM(s)');
        ensureHiddenFieldRestore('');
      } else {
        label.text(checked.join(', '));
        ensureHiddenFieldRestore(checked.join(','));
      }
      enforceVersionVisibility();
    }

    function loadRestoreFolders() {
      if (loadRestoreFoldersInProgress) return;
      loadRestoreFoldersInProgress = true;

      const restorePath = $('#location_of_backups').val().trim();
      list.empty();

      if (!restorePath) {
        dropdown.addClass('disabled').removeClass('active');
        list.hide();
        label.text('No backups at this location').css('color', '#e0c8f5');
        loadRestoreFoldersInProgress = false;
        ensureHiddenFieldRestore('');
        $('#version-fields-wrapper').hide();
        $('#version-fields-container').empty();
        return;
      }

      $.getJSON('/plugins/vm-backup-and-restore_beta/helpers/list_restore_folders.php',
        { restore_path: restorePath },
        function (data) {
          list.empty();

          if (!data.folders || data.folders.length === 0) {
            dropdown.addClass('disabled').removeClass('active');
            list.hide();
            label.text('No backups at this location').css('color', '#e0c8f5');
            ensureHiddenFieldRestore('');
            $('#version-fields-wrapper').hide();
            $('#version-fields-container').empty();
            return;
          }

          dropdown.removeClass('disabled active');
          list.hide();
          label.css('color', '#e0c8f5');

          const savedSelection = originalConfigRestoreSelection;
          const stillValidSelections = [];

          data.folders.forEach(folder => {
            const id = 'vmrestore-' + folder.replace(/\s+/g, '_');
            const item = $(`
              <div>
                <label>
                  <input type="checkbox" value="${folder}" id="${id}">
                  ${folder}
                </label>
              </div>
            `);
            if (savedSelection.includes(folder)) {
              item.find('input').prop('checked', true);
              stillValidSelections.push(folder);
            }
            list.append(item);
          });

          if (stillValidSelections.length > 0) {
            label.text(stillValidSelections.join(', '));
            ensureHiddenFieldRestore(stillValidSelections.join(','));
          } else {
            label.text('Select VM(s)');
            ensureHiddenFieldRestore('');
          }

          scheduleRebuildVersionFields();
        }
      ).fail(function () {
        dropdown.addClass('disabled').removeClass('active');
        list.hide();
        label.text('Error loading backups').css('color', '#e0c8f5');
        ensureHiddenFieldRestore('');
        $('#version-fields-wrapper').hide();
        $('#version-fields-container').empty();
      }).always(function () {
        loadRestoreFoldersInProgress = false;
      });
    }

    // Dropdown open/close
    dropdown.on('click', function (e) {
      if (dropdown.hasClass('disabled')) return;
      e.stopPropagation();
      list.toggle();
      dropdown.toggleClass('active', list.is(':visible'));
    });

    $(document).on('click', function (e) {
      if (!$(e.target).closest('#vm-dropdown-restore').length) {
        list.hide();
        dropdown.removeClass('active');
      }
    });

    list.on('click', 'input, label', function (e) { e.stopPropagation(); });

    list.on('change', 'input[type=checkbox]', function () {
      updateRestoreLabel();
      scheduleRebuildVersionFields();
    });

    // Location input changes — debounced
    let locationChangeTimer = null;
    $('#location_of_backups').on('input blur change', function () {
      const currentPath = $(this).val().trim();
      if (currentPath === lastLoadedRestorePath) return;
      lastLoadedRestorePath = currentPath;
      clearTimeout(locationChangeTimer);
      locationChangeTimer = setTimeout(function () {
        loadRestoreFolders();
        scanMalformedBackups();
      }, 300);
    });

    // Restore folder poller
    (function restoreFolderPoller() {
      const MIN_DELAY = 1000;
      if (list.is(':visible')) return setTimeout(restoreFolderPoller, MIN_DELAY);

      const restorePath = $('#location_of_backups').val().trim();
      if (!restorePath) return setTimeout(restoreFolderPoller, MIN_DELAY);

      const currentSelected = $('#vm-hidden-restore').val() || '';

      $.getJSON('/plugins/vm-backup-and-restore_beta/helpers/list_restore_folders.php',
        { restore_path: restorePath },
        function (data) {
          const newFolders = (data.folders || []).slice().sort().join(',');
          const oldFolders = list.find('input[type=checkbox]')
            .map(function () { return $(this).val(); }).get().sort().join(',');
          if (newFolders !== oldFolders) {
            originalConfigRestoreSelection = currentSelected.split(',').map(s => s.trim()).filter(Boolean);
            loadRestoreFolders();
          }
        }
      ).always(function () { setTimeout(restoreFolderPoller, MIN_DELAY); });
    })();

    loadRestoreFolders();
    enforceVersionVisibility();
    window.loadRestoreFolders = loadRestoreFolders;
  });
</script>

<script>
  const cronMode = document.getElementById('cron_mode');
  const backupbtn = document.getElementById('backupbtn');

  function updateBackupButtonState() {
    backupbtn.disabled = backupRunning;
  }

  // ── Backup UI state ───────────────────────────────────────────────────────
  function updateBackupUI(running) {
    const btn = $('#backupbtn');
    if (!running) {
      if (!backupStartTime) { return; }
      const elapsed = Date.now() - backupStartTime;
      if (elapsed < MIN_DURATION) { setTimeout(() => updateBackupUI(false), MIN_DURATION - elapsed); return; }
      backupStartTime = 0;
    } else {
      if (!backupStartTime) backupStartTime = Date.now();
    }
  }

  (function backupRunningPoller() {
    $.getJSON('/plugins/vm-backup-and-restore_beta/helpers/backup_status.php', function (res) {
      backupRunning = res.running === true;
      updateBackupButtonState();
      updateBackupUI(res.running);
    }).always(() => setTimeout(backupRunningPoller, 1000));
  })();

  // ── Path helpers ──────────────────────────────────────────────────────────
  async function fetchVdiskPaths(vmList) {
    return $.ajax({
      url: '/plugins/vm-backup-and-restore_beta/helpers/get_vdisk_paths.php',
      method: 'POST',
      data: { vms: vmList },
      dataType: 'json'
    });
  }

  async function resolvePathServer(p) {
    try {
      const res = await fetch('/plugins/vm-backup-and-restore_beta/helpers/resolve_path.php', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'path=' + encodeURIComponent(p) + '&csrf_token=' + encodeURIComponent(csrfToken)
      });
      const text = await res.text();
      return text.trim() || p;
    } catch (e) { return p; }
  }

  function backupclassifyPath(p) {
    if (p.startsWith('/mnt/user/') || p === '/mnt/user') return 'USER';
    if (p.startsWith('/mnt/user0/') || p === '/mnt/user0') return 'USER0';
    if (p.startsWith('/mnt/remotes/') || p === '/mnt/remotes') return 'EXEMPT';
    if (p.startsWith('/mnt/addons/') || p === '/mnt/addons') return 'EXEMPT';
    return 'OTHER';
  }

  // ── Backup button ─────────────────────────────────────────────────────────
  $('#backupbtn').on('click', async function () {
    if (backupRequestInProgress) return;

    const vms = $('#vm-hidden-backup').val();
    const dest = $('#backup_destination').val().trim();

    if (!vms) { alert('Please select at least one VM to backup'); return; }
    if (!dest) { alert('Please select a backup destination'); return; }

    const vmList = vms.split(',').map(v => v.trim()).filter(Boolean);
    const resolvedDest = await resolvePathServer(dest);
    const destClass = backupclassifyPath(resolvedDest);

    try {
      const data = await fetchVdiskPaths(vmList);
      for (const vm of vmList) {
        const disks = data[vm];
        if (!Array.isArray(disks)) { alert(`Could not read vdisk paths for ${vm}`); return; }
        for (const disk of disks) {
          const resolvedDisk = await resolvePathServer(disk);
          const diskClass = backupclassifyPath(resolvedDisk);
          if (diskClass !== destClass && diskClass !== 'EXEMPT' && destClass !== 'EXEMPT') {
            alert(`${vm}'s vdisk ${disk} is using mount type (${diskClass}) and backup destination (${destClass})\n\nThey must be on the same mount type i.e both fields using user or both user0 or none using either user or user0`);
            return;
          }
        }
      }
    } catch (err) { alert('Error validating vdisk paths'); console.error(err); return; }

    const services = getSelectedServices('');
    if (services.includes('Pushover') && document.getElementById('notifications')?.value === 'yes') {
      if (!$('#pushover_user_key').val().trim()) { alert('Please enter your Pushover user key'); return; }
    }

    backupRequestInProgress = true;

    const webhookParams = {};
    $('#webhook-fields-container .webhook-url-input').each(function () {
      webhookParams['WEBHOOK_' + $(this).data('service').toUpperCase()] = $(this).val().trim();
    });

    $.post('/plugins/vm-backup-and-restore_beta/helpers/save_settings.php', {
      VMS_TO_BACKUP: vms,
      BACKUP_DESTINATION: dest,
      BACKUPS_TO_KEEP: $('#backups_to_keep').val(),
      BACKUP_OWNER: $('#backup_owner').val(),
      DRY_RUN: $('#dry_run').val(),
      NOTIFICATIONS: document.getElementById('notifications')?.value || 'no',
      NOTIFICATION_SERVICE: getSelectedServices('').join(','),
      WEBHOOK_DISCORD: webhookParams['WEBHOOK_DISCORD'] || '',
      WEBHOOK_GOTIFY: webhookParams['WEBHOOK_GOTIFY'] || '',
      WEBHOOK_NTFY: webhookParams['WEBHOOK_NTFY'] || '',
      WEBHOOK_PUSHOVER: webhookParams['WEBHOOK_PUSHOVER'] || '',
      WEBHOOK_SLACK: webhookParams['WEBHOOK_SLACK'] || '',
      PUSHOVER_USER_KEY: $('#pushover_user_key').val() || '',
      csrf_token: csrfToken
    })
      .done(function (res) {
        if (res && res.status === 'ok') { startBackup(); }
        else { alert('Failed to save settings'); }
      })
      .fail(() => alert('Error saving settings'))
      .always(() => { backupRequestInProgress = false; });
  });

  function startBackup() {
    $.get('/plugins/vm-backup-and-restore_beta/helpers/backup.php', { csrf_token: csrfToken })
      .done(function (res) {
        if (res && res.status === 'ok') { console.log('Backup started, PID:', res.pid); }
        else { alert(res.message || 'Failed to start backup'); }
      })
      .fail(() => alert('Error starting backup'));
  }

  // ── Cron conflict helpers ─────────────────────────────────────────────────
  function cronToMinutesOfWeek(expr) {
    const parts = expr.trim().split(/\s+/);
    if (parts.length !== 5) return [];

    const [min, hour, dom, month, dow] = parts;
    const minutes = [];
    const MINS_IN_WEEK = 7 * 24 * 60;

    const hInterval = hour.match(/^\*\/(\d+)$/);
    if (min === '0' && hInterval && dom === '*' && month === '*' && dow === '*') {
      const n = parseInt(hInterval[1], 10);
      for (let h = 0; h < 7 * 24; h += n) minutes.push(h * 60);
      return minutes;
    }

    if (min === '0' && /^\d+$/.test(hour) && dom === '*' && month === '*' && dow === '*') {
      const h = parseInt(hour, 10);
      for (let d = 0; d < 7; d++) minutes.push(d * 24 * 60 + h * 60);
      return minutes;
    }

    if (min === '0' && /^\d+$/.test(hour) && dom === '*' && month === '*' && /^\d+$/.test(dow)) {
      const h = parseInt(hour, 10);
      const d = parseInt(dow, 10);
      minutes.push(d * 24 * 60 + h * 60);
      return minutes;
    }

    if (min === '0' && /^\d+$/.test(hour) && /^\d+$/.test(dom) && month === '*' && dow === '*') {
      const h = parseInt(hour, 10);
      const d = (parseInt(dom, 10) - 1) % 7;
      minutes.push(d * 24 * 60 + h * 60);
      return minutes;
    }

    return [];
  }

  function checkCronConflicts(newCron, existingCrons, excludeId, thresholdMinutes) {
    const newTimes = cronToMinutesOfWeek(newCron);
    if (!newTimes.length) return null;
    const MINS_IN_WEEK = 7 * 24 * 60;

    for (const entry of existingCrons) {
      if (entry.id === excludeId) continue;
      const existingTimes = cronToMinutesOfWeek(entry.cron);
      for (const nt of newTimes) {
        for (const et of existingTimes) {
          const diff = Math.min(Math.abs(nt - et), MINS_IN_WEEK - Math.abs(nt - et));
          if (diff < thresholdMinutes) return entry.cron;
        }
      }
    }
    return null;
  }

  async function fetchExistingCrons() {
    return $.getJSON('/plugins/vm-backup-and-restore_beta/helpers/schedule_cron_check.php');
  }

  // ── Schedule management ───────────────────────────────────────────────────
  window.editingScheduleId = null;

  function loadSchedules(force = false) {
    if (scheduleUILocked && !force) return $.Deferred().resolve().promise();
    return $.get('/plugins/vm-backup-and-restore_beta/helpers/schedule_list.php', function (html) {
      $('#schedule-list').html(html);
    }).always(() => unlockScheduleUI());
  }

  function buildCronFromUI() {
    const mode = $('#cron_mode').val();
    switch (mode) {
      case 'hourly': { const v = parseInt($('#hourly_frequency').val(), 10); return { valid: true, expression: `0 */${v} * * *` }; }
      case 'daily': { const h = parseInt($('#daily_time').val(), 10); const m = parseInt($('#daily_minute').val(), 10); return { valid: true, expression: `${m} ${h} * * *` }; }
      case 'weekly': {
        const dayMap = { Sunday: 0, Monday: 1, Tuesday: 2, Wednesday: 3, Thursday: 4, Friday: 5, Saturday: 6 };
        const d = dayMap[$('#weekly_day').val()];
        const h = parseInt($('#weekly_time').val(), 10);
        const m = parseInt($('#weekly_minute').val(), 10);
        return { valid: true, expression: `${m} ${h} * * ${d}` };
      }
      case 'monthly': { const d = parseInt($('#monthly_day').val(), 10); const h = parseInt($('#monthly_time').val(), 10); const m = parseInt($('#monthly_minute').val(), 10); return { valid: true, expression: `${m} ${h} ${d} * *` }; }
      default: return { valid: false };
    }
  }

  async function scheduleJob(type) {
    if (!validateBackupPrereqs()) return;
    if (scheduleUILocked) return;
    lockScheduleUI();

    const cron = buildCronFromUI();
    if (!cron.valid) { unlockScheduleUI(); alert('Invalid cron expression'); return; }

    const vms = $('#vm-hidden-backup').val();
    const dest = $('#backup_destination').val().trim();
    const vmList = vms.split(',').map(v => v.trim()).filter(Boolean);
    const resolvedDest = await resolvePathServer(dest);
    const destClass = backupclassifyPath(resolvedDest);

    try {
      const data = await fetchVdiskPaths(vmList);
      for (const vm of vmList) {
        const disks = data[vm];
        if (!Array.isArray(disks)) { unlockScheduleUI(); alert(`Could not read vdisk paths for ${vm}`); return; }
        for (const disk of disks) {
          const resolvedDisk = await resolvePathServer(disk);
          const diskClass = backupclassifyPath(resolvedDisk);
          if (diskClass !== destClass && diskClass !== 'EXEMPT' && destClass !== 'EXEMPT') {
            unlockScheduleUI();
            alert(`${vm}'s vdisk ${disk} is using mount type (${diskClass}) and backup destination (${destClass})\n\nThey must be on the same mount type i.e both fields using user or both user0 or none using either user or user0`);
            return;
          }
        }
      }
    } catch (err) { unlockScheduleUI(); alert('Error validating vdisk paths'); console.error(err); return; }

    const existingCrons = await fetchExistingCrons();
    const conflict = checkCronConflicts(cron.expression, existingCrons, window.editingScheduleId, 15);
    if (conflict) { unlockScheduleUI(); alert('This remote schedule is within 15 minutes of an existing schedule (' + conflict + '). Please choose a different time.'); return; }

    const settings = {};
    $('input[name], select[name]').each(function () { settings[this.name] = $(this).val(); });

    const url = window.editingScheduleId ? 'schedule_update.php' : 'schedule_create.php';

    $.ajax({
      type: 'POST',
      url: `/plugins/vm-backup-and-restore_beta/helpers/${url}`,
      data: { id: window.editingScheduleId, type, cron: cron.expression, settings },
      success: function () { resetScheduleUI(); window.editingScheduleId = null; loadSchedules(true); showPopup('Schedule saved!'); },
      error: function (xhr) {
        unlockScheduleUI();
        if (xhr.status === 409) { alert('Duplicate schedule detected during create!'); }
        else { alert('Error creating/updating schedule: ' + xhr.responseText); }
      }
    });
  }

  function editSchedule(id) {
    if (scheduleUILocked) return;
    lockScheduleUI();

    $.getJSON('/plugins/vm-backup-and-restore_beta/helpers/schedule_load.php', { id }, function (s) {
      const settings = s.SETTINGS || {};

      if (s.TYPE) $('[name="type"]').val(s.TYPE).trigger('change');

      for (const k in settings) {
        const el = $('[name="' + k + '"]');
        if (!el.length) continue;
        if (el.is(':checkbox')) { el.prop('checked', settings[k] == 1 || settings[k] === true); }
        else if (el.is(':radio')) { $('[name="' + k + '"][value="' + settings[k] + '"]').prop('checked', true); }
        else { el.val(settings[k]).trigger('change'); }
        if (k === 'VMS_TO_BACKUP') { $('#vm-dropdown').attr('data-selected', settings[k]); }
      }

      $('#cron_mode').val(detectCronMode(s.CRON)).trigger('change');
      window.editingScheduleId = id;
      $('#vm-dropdown').attr('data-selected', settings['VMS_TO_BACKUP'] || '');
      loadBackupVMs();

      $('#schedule-backup').text('Update');
      const $tip = $('#schedule-backup').closest('span');
      $tip.data('tooltip', 'Update the backup schedule using the settings shown in the fields above');
      if ($tip.hasClass('tooltipstered')) $tip.tooltipster('content', 'Update the backup schedule using the settings shown in the fields above');

      $('#cancelEditBtn').show();
      unlockScheduleUI();
    });
  }

  $('#cancelEditBtn').on('click', function () { location.reload(); });

  function showPopup(message) {
    const popup = $('#popupMessage');
    popup.text(message).fadeIn(150);
    setTimeout(() => popup.fadeOut(200, () => popup.text('').hide()), 3000);
  }

  function showPopuprestore(message) {
    const popup = $('#popupMessagerestore');
    popup.text(message).fadeIn(150);
    setTimeout(() => popup.fadeOut(200, () => popup.text('').hide()), 3000);
  }

  function resetScheduleUI() {
    $('#schedule-backup').text('Schedule It');
    const $tip = $('#schedule-backup').closest('span');
    $tip.data('tooltip', 'Create a backup schedule using the settings shown in the fields above');
    if ($tip.hasClass('tooltipstered')) $tip.tooltipster('content', 'Create a backup schedule using the settings shown in the fields above');
    $('#cancelEditBtn').hide();
    $('#popupMessage').stop(true, true).hide().text('');
  }

  function deleteSchedule(id) {
    if (scheduleUILocked) return;
    if (!confirm('Delete this schedule?')) return;
    lockScheduleUI();
    $.post('/plugins/vm-backup-and-restore_beta/helpers/schedule_delete.php', { id })
      .always(() => loadSchedules(true));
  }

  function runScheduleBackup(id, btn) {
    if (scheduleUILocked) return;
    if (!confirm('Are you sure you want to run this backup now?')) return;
    lockScheduleUI();
    btn.disabled = true;
    const originalText = btn.textContent;
    const originalTitle = $(btn).hasClass('tooltipstered')
      ? $(btn).tooltipster('content')
      : (btn.getAttribute('title') || 'Run schedule');

    btn.textContent = 'Running';

    $.post('/plugins/vm-backup-and-restore_beta/helpers/run_schedule.php', { id })
      .done(function (res) {
        if (!res.started) {
          alert('Failed to start backup');
          btn.disabled = false;
          btn.textContent = originalText;
          btn.setAttribute('title', originalTitle);
          unlockScheduleUI();
          return;
        }

        showBanner('backup', '⚠ Scheduled backup in progress');
        setAllBackupButtonsDisabled(true);
        prevBackupRunning = true;

        function waitForUnlock() {
          $.getJSON('/plugins/vm-backup-and-restore_beta/helpers/check_lock.php', function (data) {
            if (!data.locked) {
              btn.textContent = originalText;
              btn.setAttribute('title', originalTitle);
              if ($(btn).hasClass('tooltipstered')) $(btn).tooltipster('content', originalTitle);
              btn.onclick = function () { runScheduleBackup(id, btn); };
              hideBanner('backup');
              prevBackupRunning = false;
              setAllBackupButtonsDisabled(false);
              unlockScheduleUI();
              return;
            }
            setTimeout(waitForUnlock, 1000);
          });
        }
        waitForUnlock();
      })
      .fail(function (xhr, status, err) {
        alert('Failed to start backup: ' + (xhr.responseJSON?.error || err));
        btn.disabled = false;
        btn.textContent = originalText;
        btn.setAttribute('title', originalTitle);
        unlockScheduleUI();
      });
  }

  function toggleSchedule(id, isEnabled) {
    if (scheduleUILocked) return;
    if (!confirm(isEnabled ? 'Disable this schedule?' : 'Enable this schedule?')) return;
    lockScheduleUI();
    $.post('/plugins/vm-backup-and-restore_beta/helpers/schedule_toggle.php', { id })
      .always(() => loadSchedules(true));
  }

  function detectCronMode(cron) {
    if (!cron) return 'daily';
    if (/^0 \*\/\d+ \* \* \*$/.test(cron)) return 'hourly';
    if (/^\d+ \d+ \* \* \*$/.test(cron)) return 'daily';
    if (/^\d+ \d+ \* \* [0-6]$/.test(cron)) return 'weekly';
    if (/^\d+ \d+ \d+ \* \*$/.test(cron)) return 'monthly';
    return 'daily';
  }

  $(document).ready(function () {
    loadSchedules();
    $(document).on('click', '#schedule-backup', function () { scheduleJob('backup'); });
    $(document).on('click', '#schedule-restore', function () { scheduleJob('restore'); });
  });
</script>

<script>
  function updateRestoreUI(running) {
    if (!running) {
      if (!restoreStartTime) { return; }
      const elapsed = Date.now() - restoreStartTime;
      if (elapsed < MIN_RESTORE_DURATION) { setTimeout(() => updateRestoreUI(false), MIN_RESTORE_DURATION - elapsed); return; }
      restoreStartTime = 0;
    } else {
      if (!restoreStartTime) restoreStartTime = Date.now();
    }
  }

  (function restoreRunningPoller() {
    $.getJSON('/plugins/vm-backup-and-restore_beta/helpers/restore_status.php', function (res) {
      updateRestoreUI(res.running);
    }).always(() => setTimeout(restoreRunningPoller, 1000));
  })();

  function collectRestoreVersions() {
    const versions = {};
    $('#version-fields-container select.version-select').each(function () {
      const vm = $(this).data('vm');
      const val = $(this).val();
      if (vm && val) versions[vm] = val;
    });
    return versions;
  }

  function classifyPath(p) {
    if (p.startsWith('/mnt/user/') || p === '/mnt/user') return 'USER';
    if (p.startsWith('/mnt/user0/') || p === '/mnt/user0') return 'USER0';
    if (p.startsWith('/mnt/remotes/') || p === '/mnt/remotes') return 'EXEMPT';
    if (p.startsWith('/mnt/addons/') || p === '/mnt/addons') return 'EXEMPT';
    return 'OTHER';
  }

  $('#restorebtn').on('click', async function () {
    const vms_restore = $('#vm-hidden-restore').val();
    const dest = $('#location_of_backups').val().trim();
    const restore_dest = $('#restore_destination').val().trim();

    if (!vms_restore) { alert('Please select at least one VM to restore'); return; }
    if (!dest) { alert('Please set location of backups'); return; }
    if (!restore_dest) { alert('Please set a restore destination'); return; }

    const resolvedSrc = await resolvePathServer(dest);
    const resolvedDst = await resolvePathServer(restore_dest);
    const srcClass = classifyPath(resolvedSrc);
    const dstClass = classifyPath(resolvedDst);

    if (srcClass !== dstClass) {
      alert(`Location of backups is using mount type (${srcClass}) and restore destination (${dstClass}). They must be on the same mount type i.e both fields using user or both user0 or none using either user or user0`);
      return;
    }

    const servicesRestore = getSelectedServices('restore');
    if (servicesRestore.includes('Pushover') && document.getElementById('notifications_restore')?.value === 'yes') {
      if (!$('#pushover_user_key_restore').val().trim()) { alert('Please enter your Pushover user key'); return; }
    }

    if ($('#restorebtn').prop('disabled')) return;

    const restoreVersions = collectRestoreVersions();
    const restoreVersionsStr = Object.entries(restoreVersions).map(([vm, ver]) => `${vm}=${ver}`).join(',');

    const webhookParamsRestore = {};
    $('#webhook-fields-container-restore .webhook-url-input').each(function () {
      webhookParamsRestore['WEBHOOK_' + $(this).data('service').toUpperCase() + '_RESTORE'] = $(this).val().trim();
    });

    $.post('/plugins/vm-backup-and-restore_beta/helpers/save_settings_restore.php', {
      LOCATION_OF_BACKUPS: dest,
      VMS_TO_RESTORE: vms_restore,
      VERSIONS: restoreVersionsStr,
      RESTORE_DESTINATION: restore_dest,
      DRY_RUN_RESTORE: $('#dry_run_restore').val(),
      NOTIFICATIONS_RESTORE: document.getElementById('notifications_restore')?.value || 'no',
      NOTIFICATION_SERVICE_RESTORE: getSelectedServices('restore').join(','),
      WEBHOOK_DISCORD_RESTORE: webhookParamsRestore['WEBHOOK_DISCORD_RESTORE'] || '',
      WEBHOOK_GOTIFY_RESTORE: webhookParamsRestore['WEBHOOK_GOTIFY_RESTORE'] || '',
      WEBHOOK_NTFY_RESTORE: webhookParamsRestore['WEBHOOK_NTFY_RESTORE'] || '',
      WEBHOOK_PUSHOVER_RESTORE: webhookParamsRestore['WEBHOOK_PUSHOVER_RESTORE'] || '',
      WEBHOOK_SLACK_RESTORE: webhookParamsRestore['WEBHOOK_SLACK_RESTORE'] || '',
      PUSHOVER_USER_KEY_RESTORE: $('#pushover_user_key_restore').val() || '',
      csrf_token: csrfToken
    })
      .done(function (res) {
        if (res && res.status === 'ok') { startRestore(); }
        else { alert('Failed to save settings'); }
      })
      .fail(() => alert('Error saving settings'));
  });

  function startRestore() {
    $.get('/plugins/vm-backup-and-restore_beta/helpers/restore.php', { csrf_token: csrfToken })
      .done(function (res) {
        if (res && res.status === 'ok') { console.log('Restore started, PID:', res.pid); }
        else { alert(res.message || 'Failed to start restore'); }
      })
      .fail(() => alert('Error starting restore'));
  }

  if (typeof caPluginUpdateCheck === 'function') {
    caPluginUpdateCheck('vm-backup-and-restore_beta.plg', { name: 'vm-backup-and-restore_beta' });
  }
</script>

<script>
  let currentPath = '/mnt';
  let selectedFolder = null;

  function resolveAndApplyPath(selectedPath, targetInputId) {
    const params = new URLSearchParams({ path: selectedPath, csrf_token: csrf_token });

    fetch('/plugins/vm-backup-and-restore_beta/helpers/resolve_path.php', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: params.toString()
    })
      .then(r => r.text())
      .then(resolvedPath => {
        const $field = $('#' + targetInputId);
        $field.val(resolvedPath || selectedPath);
        $field.trigger('input').trigger('change');
        $('#folderPickerModal').hide();
      })
      .catch(() => {
        const $field = $('#' + targetInputId);
        $field.val(selectedPath);
        $field.trigger('change');
        $('#folderPickerModal').hide();
      });
  }

  function loadFolders(path) {
    $.getJSON('/plugins/vm-backup-and-restore_beta/helpers/list_folders.php',
      { path, field: activeInputFieldId },
      function (data) {
        currentPath = data.current;
        selectedFolder = null;

        const parts = currentPath.split('/').filter(p => p !== '');
        let buildPath = '';
        let breadcrumbHTML = parts.map((part, index) => {
          buildPath += '/' + part;
          const sep = index < parts.length - 1 ? ' / ' : '';
          return `<span class="breadcrumb-part" data-path="${buildPath}" style="cursor:pointer;">${part}</span>${sep}`;
        }).join('');

        $('#folderBreadcrumb').html(breadcrumbHTML);

        let html = '';

        if (data.parent) {
          html += `
            <div class="vm-folder-item browse-row" data-path="${data.parent}" style="cursor:pointer;display:flex;align-items:center;">
              .. Up Directory
            </div>
          `;
        }

        data.folders.forEach(folder => {
          const disabledAttr = folder.selectable ? '' : 'disabled';
          const disabledStyle = folder.selectable ? '' : 'style="opacity:0.4;"';
          html += `
            <div class="vm-folder-item browse-row" data-path="${folder.path}" style="display:flex;align-items:center;gap:0px;">
              <label class="folder-check-label" style="display:flex;align-items:center;cursor:pointer;padding:9px 2px 4px 4px;">
                <input type="checkbox" class="folder-checkbox" value="${folder.path}" ${disabledAttr} ${disabledStyle}>
              </label>
              <span class="folder-name-label" style="flex:1;cursor:pointer;">${folder.name}</span>
            </div>
          `;
        });

        $('#folderList').html(html);

        $('.breadcrumb-part').off('click').on('click', function () { loadFolders($(this).data('path')); });

        $('.browse-row').off('click').on('click', function (e) {
          if ($(e.target).closest('.folder-check-label, .folder-name-label').length) return;
          loadFolders($(this).data('path'));
        });

        $('.folder-name-label').off('click').on('click', function () {
          loadFolders($(this).closest('.browse-row').data('path'));
        });

        $('.folder-check-label').off('click').on('click', function (e) { e.stopPropagation(); });

        $('.folder-checkbox').off('change').on('change', function (e) {
          if (this.disabled) return;
          $('.folder-checkbox').not(this).prop('checked', false);
          selectedFolder = this.checked ? $(this).val() : null;
          e.stopPropagation();
        });
      }
    );
  }

  let activeInputFieldId = null;

  $('input[data-picker-title]').on('click', function () {
    activeInputFieldId = $(this).attr('id');
    $('#folderPickerTitle').text($(this).data('picker-title'));
    $('#folderPickerModal').show();
    const savedPath = $(this).val();
    loadFolders(savedPath && savedPath.startsWith('/mnt') ? savedPath : '/mnt');
  });

  $('#closeFolderPicker').on('click', function () { $('#folderPickerModal').hide(); });

  $('#confirmFolderSelection').off('click').on('click', function (e) {
    e.preventDefault();
    if (!selectedFolder || !activeInputFieldId) return;
    resolveAndApplyPath(selectedFolder, activeInputFieldId);
  });

  $('#createFolderBtn').on('click', function () {
    $('#newFolderInputWrap').show();
    $('#newFolderName').val('').focus();
  });

  $('#newFolderCancel').on('click', function () {
    $('#newFolderInputWrap').hide();
    $('#newFolderName').val('');
  });

  $('#newFolderOk').on('click', function () {
    const name = $('#newFolderName').val().trim();
    if (!name) return;
    $.post('/plugins/vm-backup-and-restore_beta/helpers/create_folder.php',
      { path: currentPath, name, csrf_token },
      function (res) {
        if (res.success) {
          $('#newFolderInputWrap').hide();
          $('#newFolderName').val('');
          loadFolders(currentPath);
        } else {
          alert(res.error || 'Failed to create folder');
        }
      }, 'json'
    );
  });

  $(document).ready(function () {
    const $field = $('#restore_destination');
    if ($field.length && $field.val().startsWith('/mnt/user/')) {
      resolveAndApplyPath($field.val(), 'restore_destination');
    }
  });
</script>

<script>
  let bannerStopTarget = null; // 'backup' | 'restore' | null
  let prevBackupRunning = false;
  let prevRestoreRunning = false;

  function showBanner(type, label) {
    bannerStopTarget = type;
    if (type === 'restore') {
      $('#restore-banner-text').text(label);
      $('#stop-toast-banner-restore').removeClass('visible');
      $('#restore-banner').show();
    } else {
      $('#backup-banner-text').text(label);
      $('#stop-toast-banner').removeClass('visible');
      $('#backup-banner').show();
    }
  }

  function hideBanner(type) {
    if (type === 'restore') {
      $('#restore-banner').hide();
      $('#stop-toast-banner-restore').removeClass('visible');
    } else {
      $('#backup-banner').hide();
      $('#stop-toast-banner').removeClass('visible');
    }
    if (bannerStopTarget === type) bannerStopTarget = null;
  }

  function stopFromBanner(type) {
    var url = type === 'restore'
      ? '/plugins/vm-backup-and-restore_beta/helpers/stop_restore.php'
      : '/plugins/vm-backup-and-restore_beta/helpers/stop_backup.php';
    $.post(url, { csrf_token: csrfToken })
      .done(function () {
        if (type === 'restore') {
          $('#stop-toast-banner-restore').addClass('visible');
          setTimeout(function () { $('#stop-toast-banner-restore').removeClass('visible'); }, 3000);
        } else {
          $('#stop-toast-banner').addClass('visible');
          setTimeout(function () { $('#stop-toast-banner').removeClass('visible'); }, 3000);
        }
      })
      .fail(function () { alert('Error sending stop request'); });
  }

  function setAllBackupButtonsDisabled(disabled) {
    $('#backupbtn, #restorebtn').prop('disabled', disabled);
    document.querySelectorAll('.run-schedule-btn').forEach(function (b) {
      b.disabled = disabled;
    });
  }

  (function () {
    const CHECK_INTERVAL = 1000;

    function updateRunButtons(locked, anyLocked, scheduleLocked) {
      document.querySelectorAll('.run-schedule-btn').forEach(btn => {
        btn.disabled = anyLocked;
        btn.classList.toggle('disabled', anyLocked);
      });

      if ((locked || scheduleLocked) && !prevBackupRunning) {
        var label = scheduleLocked ? '⚠ Scheduled backup in progress' : '⚠ Backup in progress';
        showBanner('backup', label);
        setAllBackupButtonsDisabled(true);
        prevBackupRunning = true;
      } else if (!locked && !scheduleLocked && prevBackupRunning) {
        hideBanner('backup');
        if (!prevRestoreRunning) setAllBackupButtonsDisabled(false);
        prevBackupRunning = false;
      }

      $('#backup-status').hide();
    }

    function updateRestoreButton(locked) {
      if (locked && !prevRestoreRunning) {
        showBanner('restore', '⚠ Restore in progress');
        setAllBackupButtonsDisabled(true);
        prevRestoreRunning = true;
      } else if (!locked && prevRestoreRunning) {
        hideBanner('restore');
        if (!prevBackupRunning) setAllBackupButtonsDisabled(false);
        prevRestoreRunning = false;
      }
      $('#restore-status').hide();
    }

    (function lockPoller() {
      fetch('/plugins/vm-backup-and-restore_beta/helpers/check_lock.php')
        .then(r => r.json())
        .then(data => {
          updateRunButtons(
            data.locked && data.mode === 'manual',
            data.locked,
            data.locked && data.mode === 'schedule'
          );
          updateRestoreButton(data.locked && data.mode === 'restore');
        })
        .catch(err => console.error('Failed to check lock:', err))
        .finally(() => setTimeout(lockPoller, CHECK_INTERVAL));
    })();
  })();
</script>

<script>
  // ── Log section ───────────────────────────────────────────────────────────
  var logAutoScroll = true;

  function applyLogSearch() {
    var logEl = document.getElementById('last-run-log');
    var countEl = document.getElementById('log-search-count');
    var term = (document.getElementById('log-search').value || '').trim();
    var raw = logEl.dataset.raw || '';
    if (!term) {
      logEl.textContent = raw || 'VM backup & restore log not found';
      countEl.classList.remove('visible');
      return;
    }
    var escaped = term.replace(/[.*+?^${}()|[\]\\]/g, '\$&');
    var re = new RegExp('(' + escaped + ')', 'gi');
    var parts = raw.split(re);
    var matches = 0;
    logEl.innerHTML = '';
    parts.forEach(function(part) {
      if (re.test(part)) {
        matches++;
        var mark = document.createElement('mark');
        mark.className = 'log-highlight';
        mark.textContent = part;
        logEl.appendChild(mark);
        re.lastIndex = 0;
      } else {
        logEl.appendChild(document.createTextNode(part));
      }
    });
    countEl.textContent = matches + ' match' + (matches !== 1 ? 'es' : '');
    countEl.classList.toggle('visible', matches > 0);
  }

  function loadLastRunLog() {
    fetch('/plugins/vm-backup-and-restore_beta/helpers/fetch_last_run_log.php')
      .then(res => res.text()).then(data => {
        var logEl = document.getElementById('last-run-log');
        var text = data || 'VM backup & restore log not found';
        logEl.dataset.raw = text;
        applyLogSearch();
        if (logAutoScroll) { logEl.scrollTop = logEl.scrollHeight; }
      })
      .catch(() => {
        var logEl = document.getElementById('last-run-log');
        logEl.dataset.raw = 'Error loading VM backup & restore log';
        logEl.textContent = 'Error loading VM backup & restore log';
      });
  }
  loadLastRunLog();
  setInterval(loadLastRunLog, 1000);

  document.getElementById('log-search').addEventListener('input', applyLogSearch);

  var autoScrollBtn = document.getElementById('log-autoscroll-btn');
  autoScrollBtn.addEventListener('click', function() {
    logAutoScroll = !logAutoScroll;
    if (logAutoScroll) {
      var logEl = document.getElementById('last-run-log');
      logEl.scrollTop = logEl.scrollHeight;
    }
  });

  document.getElementById('log-scroll-top-btn').addEventListener('click', function() {
    logAutoScroll = false;
    document.getElementById('last-run-log').scrollTop = 0;
  });

  document.getElementById('last-run-log').addEventListener('scroll', function() {
    var atBottom = this.scrollHeight - this.scrollTop - this.clientHeight < 8;
    if (!atBottom && logAutoScroll) {
      logAutoScroll = false;
    }
  });

  const clearLastRunBtn = document.getElementById('clear-last-run-log');
  if (clearLastRunBtn) {
    clearLastRunBtn.addEventListener('click', function () {
      if (confirm('Are you sure you want to clear the backup & restore Log?')) {
        fetch('/plugins/vm-backup-and-restore_beta/helpers/clear_log.php', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-TOKEN': csrfToken },
          body: 'log=last&csrf_token=' + encodeURIComponent(csrfToken)
        })
          .then(r => r.json())
          .then(data => {
            if (data.ok) {
              var logEl = document.getElementById('last-run-log');
              logEl.dataset.raw = '';
              logEl.textContent = '';
              document.getElementById('log-search-count').classList.remove('visible');
              showLogToast('Log cleared');
            }
          })
          .catch(() => { alert('Failed to clear log'); });
      }
    });
  }

  document.getElementById('copy-last-run-log').addEventListener('click', function () {
    const logEl = document.getElementById('last-run-log');
    const text = logEl.dataset.raw || logEl.textContent || '';
    if (!text.trim() || text.includes('VM backup & restore log not found')) return;
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(() => showLogToast('Log copied')).catch(err => { console.warn('Clipboard API failed', err); fallbackCopyText(text); });
    } else { fallbackCopyText(text); }
  });

  function fallbackCopyText(text) {
    const textarea = document.createElement('textarea'); textarea.value = text; document.body.appendChild(textarea); textarea.select();
    try { document.execCommand('copy'); showLogToast('Log copied'); } catch (err) { console.error('Fallback copy failed', err); alert('Failed to copy log'); }
    document.body.removeChild(textarea);
  }

  function showLogToast(message) {
    const toast = document.getElementById('log-toast');
    if (!toast) return;
    toast.textContent = message;
    toast.classList.add('visible');
    clearTimeout(toast._hideTimer);
    toast._hideTimer = setTimeout(() => { toast.classList.remove('visible'); }, 2000);
  }

  function debounceButton(btn, delay = 500) {
    let cooling = false;
    btn.addEventListener('click', function () {
      if (cooling) return;
      cooling = true;
      setTimeout(() => cooling = false, delay);
    });
  }

  ['backupbtn', 'restorebtn', 'schedule-backup', 'cancelEditBtn', 'clear-last-run-log',
    'copy-last-run-log', 'confirmFolderSelection', 'closeFolderPicker'].forEach(id => {
      const btn = document.getElementById(id);
      if (btn) debounceButton(btn);
    });
</script>

<script>
  // ── Inline help icons ─────────────────────────────────────────────────────
  $(document).ready(function () {
    let _fbbLastClick = 0;
    let _fbbF1Open = false;

    function attachHelp($trigger, helpText, $insertAfter) {
      const helpId = 'fbb-help-' + Math.random().toString(36).substr(2, 9);
      const $helpDiv = $('<div class="fbb-help-text" id="' + helpId + '" style="display:none;">' + helpText + '</div>');
      $insertAfter.after($helpDiv);
      $helpDiv.data('fbb-guard', $insertAfter);
      $trigger.addClass('fbb-has-help');

      $trigger.on('click', function () {
        _fbbLastClick = Date.now();
        const $help = $('#' + helpId);
        $help.is(':visible') ? $help.slideUp(150) : $help.slideDown(150);
      });
    }

    window._fbbAttachHelp = attachHelp;

    function processHelpLabels($scope) {
      $scope.find('label > span[class*="betatip"][title], label > span[class*="restoretip"][title]').each(function () {
        const $span = $(this);
        const helpText = $span.attr('title');
        if (!helpText) return;
        $span.removeAttr('title').attr('class', '');
        const $label = $span.closest('label');
        if ($label.hasClass('fbb-has-help')) return;
        const $formPair = $label.closest('.form-pair');
        attachHelp($label, helpText, $formPair.length ? $formPair : $label);
      });

      $scope.find('label[title]').each(function () {
        const $label = $(this);
        const helpText = $label.attr('title');
        if (!helpText || $label.hasClass('fbb-has-help')) return;
        $label.removeAttr('title');
        const $formPair = $label.closest('.form-pair');
        attachHelp($label, helpText, $formPair.length ? $formPair : $label);
      });
    }

    window._fbbProcessLabels = processHelpLabels;

    processHelpLabels($(document));

    $('span.status-label.vm-backup-and-restore_betatip[title], span.restore-status-label.vm-backup-and-restore_betatip[title]').each(function () {
      const $span = $(this);
      const helpText = $span.attr('title');
      if (!helpText) return;
      $span.removeAttr('title').removeClass('vm-backup-and-restore_betatip');
      const $statusRow = $span.closest('.status-row, .restore-status-row');
      attachHelp($span, helpText, $statusRow.length ? $statusRow : $span);
    });

    $('span.vm-backup-and-restore_betatip').each(function () {
      if ($(this).children('button').length > 0) return;
      $(this).removeAttr('title').removeClass('vm-backup-and-restore_betatip');
    });

    $('div.vm-backup-and-restore_betatip').each(function () {
      if ($(this).closest('table').length > 0) return;
      $(this).removeAttr('title').removeClass('vm-backup-and-restore_betatip');
    });

    $(document).on('keydown', function (e) {
      if (e.key !== 'F1') return;
      e.preventDefault();
      if (_fbbF1Open) {
        $('.fbb-help-text').slideUp(150);
        _fbbF1Open = false;
      } else {
        $('.fbb-help-text').each(function () {
          const $guard = $(this).data('fbb-guard');
          if ($guard && !$guard.is(':visible')) return;
          $(this).slideDown(150);
        });
        _fbbF1Open = true;
      }
    });

    $(document).on('click', function () {
      if (Date.now() - _fbbLastClick < 150) return;
      $('.fbb-help-text').slideUp(150);
      _fbbF1Open = false;
    });
  });

  // Initial deferred calls
  $(document).ready(function () {
    setTimeout(scheduleRebuildVersionFields, 50);
    setTimeout(scanMalformedBackups, 100);

    $('#location_of_backups').on('change', scanMalformedBackups);

    scanMalformedBackups();
    startMalformedPolling();
  });
</script>
